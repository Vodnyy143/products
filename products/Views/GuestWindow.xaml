<Window x:Class="products.Views.GuestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:products.Views"
        xmlns:vm="clr-namespace:products.ViewModels"
        mc:Ignorable="d"
        Title="GuestWindow" Height="450" Width="800">
    <Window.DataContext>
        <vm:GuestViewModel />
    </Window.DataContext>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>  
        
        <Button
            Grid.Row="0"
            Content="Выйти"
            Command="{Binding LogoutCommand}"
            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
            />
        
        <ListBox 
            Grid.Row="1"
            ItemsSource="{Binding Products}"
            >
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        
                        <Image Grid.Column="0" Source="{Binding PhotoPath}" Width="100" Height="100"/>
                        
                        <StackPanel Grid.Column="1">
                            <TextBlock>
                                <Run Text="{Binding Category.Name}"/>
                                <Run Text="{Binding Name}"/>
                            </TextBlock>
                            <TextBlock Text="{Binding Description}"/>
                            <TextBlock>
                                <Run Text="Производитель:"/>
                                <Run Text="{Binding Manufacturer.Name}"/>
                            </TextBlock>
                            <TextBlock>
                                <Run Text="Поставщик:"/>
                                <Run Text="{Binding Supplier.Name}"/>
                            </TextBlock>
                            <TextBlock>
                                <Run Text="Единица измерения:"/>
                                <Run Text="{Binding Unit.Name}"/>
                            </TextBlock>
                            <TextBlock>
                                <Run Text="Количество на складе:"/>
                                <Run Text="{Binding Quantity}"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
