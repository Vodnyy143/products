<Window x:Class="products.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:products.Views"
        mc:Ignorable="d"
        Title="AdminWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Image Grid.Column="0" Source="/Resources/Icon.png" Width="40" Height="40"/>
                
                <TextBlock Grid.Column="1" Text="ООО Обувь - Администрация"/>
                
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Администратор"/>
                    <TextBlock Text="{Binding UserFullName}"/>
                </StackPanel>
                
                <Button 
                    Grid.Column="3" 
                    Content="Выйти" 
                    Command="{Binding LogoutCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    />
            </Grid>
        </Border>
        
        <Border Grid.Row="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <DockPanel Grid.Column="0">
                    <Label Content="Поиск" DockPanel.Dock="Left"/>
                    <TextBlock Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                </DockPanel>
                
                <StackPanel Grid.Column="1">
                    <Label Content="Поставщик:"/>
                    <ComboBox
                        ItemsSource="{Binding Suppliers}"
                        SelectedItem="{Binding SelectedSupplier}"
                        DisplayMemberPath="Name"
                        />
                </StackPanel>
                
                <Button Grid.Column="2" Content="{Binding SortLabel}" Command="{Binding ToggleSortCommand}" />
                
                <Button Grid.Column="3" Content="Заказы" Command="{Binding OpenOrdersCommandd}" />
                
                <Button 
                    Grid.Column="4" 
                    Content="+ Добавить товар" 
                    Command="{Binding AddProductCommand}" 
                    />
            </Grid>
        </Border>
        
        <ListBox Grid.Row="2"
                 ItemsSource="{Binding FilteredProducts}"
                 HorizontalContentAlignment="Stretch"
                 Margin="10"
                 BorderThickness="0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border 
                            BorderBrush="Gray"
                            BorderThickness="1"
                            Padding="10"
                            Margin="0,3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="Auto"/>
                                <!-- Кнопки -->
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" BorderBrush="Black" BorderThickness="1"
                                    Width="100" Height="100">
                                <Image Source="{Binding PhotoPath}" Stretch="Uniform"/>
                            </Border>

                            <StackPanel Grid.Column="1" Margin="15,0,0,0">
                                <TextBlock FontWeight="Bold" FontSize="15">
                                    <Run Text="{Binding Category.Name}"/>
                                    <Run Text=" | "/>
                                    <Run Text="{Binding Name}"/>
                                </TextBlock>
                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap"/>
                                <TextBlock>
                                    <Run Text="Артикул: "/>
                                    <Run Text="{Binding Article}" FontWeight="Bold"/>
                                </TextBlock>
                                <TextBlock>
                                    <Run Text="Производитель: "/>
                                    <Run Text="{Binding Manufacturer.Name}"/>
                                </TextBlock>
                                <TextBlock>
                                    <Run Text="Поставщик: "/>
                                    <Run Text="{Binding Supplier.Name}"/>
                                </TextBlock>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Цена: "/>
                                    <TextBlock Text="{Binding Price, StringFormat={}{0:0.00} ₽}"
                                               Foreground="Red"
                                               TextDecorations="Strikethrough"/>
                                    <TextBlock Text="{Binding FinalPrice, StringFormat={}{0:0.00} ₽}"
                                               Foreground="Black" Margin="8,0,0,0" FontWeight="Bold"/>
                                </StackPanel>
                                <TextBlock>
                                    <Run Text="На складе: "/>
                                    <Run Text="{Binding Quantity}" FontWeight="Bold"/>
                                </TextBlock>
                            </StackPanel>

                            <Border Grid.Column="2" BorderBrush="Black" BorderThickness="1"
                                    VerticalAlignment="Center">
                                <StackPanel HorizontalAlignment="Center" Margin="5">
                                    <TextBlock Text="Скидка:" HorizontalAlignment="Center" FontSize="12"/>
                                    <TextBlock Text="{Binding Discount, StringFormat={}{0}%}"
                                               HorizontalAlignment="Center"
                                               FontSize="22" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <!-- Кнопки CRUD (только для админа) -->
                            <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="10,0,0,0">
                                <Button Content="✎ Изменить"
                                        Command="{Binding DataContext.EditProductCommand,
                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Width="100" Margin="3"/>
                                <Button Content="✕ Удалить"
                                        Command="{Binding DataContext.DeleteProductCommand,
                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Background="#FFB6B6"
                                        Width="100" Margin="3"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
