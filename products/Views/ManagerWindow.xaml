<Window x:Class="products.Views.ManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:products.Views"
        mc:Ignorable="d"
        Title="ManagerWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Image Grid.Column="0" Source="/Resources/Icon.png" Width="40" Height="40"/>
                
                <TextBlock Grid.Column="1" Text="ООО Обувь - Управление" VerticalAlignment="Center"/>
                
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Менеджер:"/>
                    <TextBlock Text="{Binding UserFullName}"/>
                </StackPanel>
                
                <Button Grid.Column="3" 
                        Content="Выйти"
                        Command="{Binding LogoutCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                />
            </Grid>
        </Border>
        
        <Border Grid.Row="1">
            
        </Border>
        
        <ListBox 
            Grid.Row="2"
            ItemsSource="{Binding FilteredProducts}"
        >
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        
                        <Image Grid.Column="0" Source="{Binding PhotoPath}" Width="100" Height="100"/>
                        
                        <StackPanel Grid.Column="1">
                            <TextBlock>
                                <Run Text="{Binding Category.Name}"/>
                                <Run Text="{Binding Name}"/>
                            </TextBlock>
                            <TextBlock Text="{Binding Description}"/>
                            <TextBlock>
                                <Run Text="Производитель:"/>
                                <Run Text="{Binding Manufacturer.Name}"/>
                            </TextBlock>
                            <TextBlock>
                                <Run Text="Поставщик:"/>
                                <Run Text="{Binding Supplier.Name}"/>
                            </TextBlock>
                            <TextBlock>
                                <Run Text="Единица измерения:"/>
                                <Run Text="{Binding Unit.Name}"/>
                            </TextBlock>
                            <TextBlock>
                                <Run Text="Количество на складе:"/>
                                <Run Text="{Binding Quantity}"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
